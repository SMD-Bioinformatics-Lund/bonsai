{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    // Set to true during dev work, false in production
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "components/*": ["web/js/components/*"],
      "core/*": ["web/js/core/*"],
      "utils/*": ["web/js/utils/*"],
      "views/*": ["web/js/views/*"]
    },
  }
}