###############################################################################
# Bonsai settings                                                             #
###############################################################################

# See docs for all available options.

FLASK_ENV=development 
TZ=Europe/Stockholm

# Automatically create a default admin user on startup
BONSAI_ADMIN_USER=admin
BONSAI_ADMIN_PASSWORD=admin123 

ALLOWED_ORIGINS=["*"]
DB_HOST=mongodb

# Users for doing uploads when bootstraping a new instance
BONSAI_USER=admin
BONSAI_PASSWD=admin123

# API url configuration
API_EXTERNAL_URL=http://127.0.0.1:8001
API_INTERNAL_URL=http://api:8000

# Intervall for running periodic cleanup jobs on minhash service
# Use a util like this to generate Cron syntax: https://crontab.guru/
INTEGRITY_TASK_CRON=*/30 * * * *
PURGE_FILES_TASK_CRON=*/30 * * * *